# Source maps — never shipped to users (large, and flagged by the Marketplace scan).
**/*.map

# Build inputs / tooling not needed at runtime.
scripts/**
src/renderer/**
node_modules/**

# Tests and dev artifacts.
test/**
*.vsix

# Repo noise.
.gitignore
.vscode/**

# Local dev data — never ship (per-project time tracking is private, not runtime).
.timelog/**

# OneDrive sync-conflict duplicates that landed in the tree.
**/*-Or-Laptop*
**/*Or-Laptop*
