{
  "name": "agentville-launcher",
  "displayName": "Agentville Launcher",
  "description": "A live top-down town view of your Claude Code agents — opens in a VSCode tab, with a 🌍 button in the Claude panel and status bar.",
  "version": "0.1.6",
  "publisher": "OrBenozio",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/orbenozio/claude-code-agentville.git"
  },
  "homepage": "https://github.com/orbenozio/claude-code-agentville#readme",
  "bugs": {
    "url": "https://github.com/orbenozio/claude-code-agentville/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "agentville",
    "visualization"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "onUri",
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agentville.open",
        "title": "Agentville: Open the town view"
      },
      {
        "command": "agentville.checkAndInject",
        "title": "Agentville: Add button to Claude panel (inject)"
      },
      {
        "command": "agentville.removeInjection",
        "title": "Agentville: Remove button from Claude panel"
      }
    ],
    "configuration": {
      "title": "Agentville",
      "properties": {
        "agentville.autoInject": {
          "type": "boolean",
          "default": true,
          "description": "Automatically add the Agentville button to the Claude Code panel on startup and re-add it after Claude updates."
        },
        "agentville.reinjectCheckHours": {
          "type": "number",
          "default": 6,
          "minimum": 0,
          "maximum": 48,
          "description": "How often (hours) to re-check/re-add the button after Claude Code updates (0 = disabled)."
        }
      }
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "vscode:prepublish": "node scripts/build.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.24.2"
  }
}
